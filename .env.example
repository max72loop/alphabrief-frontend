# Copy this file to .env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL and anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the client.
# Used by API routes (webhooks, digest cron) for admin operations.
SUPABASE_SERVICE_ROLE_KEY=

# ── Lemon Squeezy (paiements) ─────────────────────────────────────────────
# URL de checkout publique — bouton "Passer à Premium"
NEXT_PUBLIC_LEMON_CHECKOUT_URL=https://your-store.lemonsqueezy.com/checkout/buy/your-variant-id

# Secret de signature des webhooks (configuré dans le dashboard Lemon Squeezy)
LEMON_WEBHOOK_SECRET=

# ── Cron / Digest hebdomadaire (optionnel) ────────────────────────────────
# Bearer token pour authentifier les appels à /api/digest depuis un cron externe
CRON_SECRET=

# Resend — envoi du digest email aux utilisateurs Premium
# Obtenir une clé sur https://resend.com
RESEND_API_KEY=
